{
  "name": "@micro-harness/plugin-subagents",
  "version": "0.1.0",
  "description": "spawn_subagent tool built on @micro-harness/core's InProcessSubagentRunner.",
  "license": "MIT",
  "keywords": ["micro-harness", "plugin", "subagents", "delegation"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.test.d.ts"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "peerDependencies": {
    "@micro-harness/core": "^0.3.0"
  }
}
