{
  "name": "@micro-harness/plugin-basic-tools",
  "version": "0.1.0",
  "description": "Workspace-scoped file, grep, and shell tools for @micro-harness/core.",
  "license": "MIT",
  "keywords": ["micro-harness", "plugin", "tools", "filesystem", "shell", "grep"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.test.d.ts"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "peerDependencies": {
    "@micro-harness/core": "^0.3.0"
  }
}
