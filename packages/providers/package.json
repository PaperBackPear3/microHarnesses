{
  "name": "@micro-harness/providers",
  "version": "0.1.0",
  "description": "Provider plugins (OpenAI, Anthropic, Ollama) for @micro-harness/core. Each provider is a HarnessPlugin that registers its adapter and env-based credentials resolver.",
  "license": "MIT",
  "keywords": ["micro-harness", "llm", "openai", "anthropic", "ollama"],
  "homepage": "https://paperbackpear3.github.io/microHarnesses/",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaperBackPear3/microHarnesses.git",
    "directory": "packages/providers"
  },
  "bugs": {
    "url": "https://github.com/PaperBackPear3/microHarnesses/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.test.d.ts"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "peerDependencies": {
    "@micro-harness/core": "^0.3.0"
  }
}
