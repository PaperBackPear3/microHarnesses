{
  "name": "micro-harnesses",
  "version": "3.4.3",
  "private": true,
  "description": "Library-first framework for building micro harnesses.",
  "homepage": "https://paperbackpear3.github.io/microHarnesses/",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaperBackPear3/microHarnesses.git"
  },
  "bugs": {
    "url": "https://github.com/PaperBackPear3/microHarnesses/issues"
  },
  "keywords": ["micro-harness", "llm", "ai-agent", "typescript", "plugin-system", "tool-calling"],
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["packages/*", "plugins/*", "apps/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run build && npm run test --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome format --write .",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.20.0",
    "typescript": "^5.7.2"
  }
}
