{
  "name": "@micro-harnesses/plugin-example-tools",
  "version": "3.0.9",
  "description": "Reference tool plugin (echo, time) for @micro-harnesses/core. Doubles as a plugin-authoring example.",
  "license": "MIT",
  "keywords": ["micro-harness", "plugin", "example", "tools"],
  "homepage": "https://paperbackpear3.github.io/microHarnesses/",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaperBackPear3/microHarnesses.git",
    "directory": "plugins/example-tools"
  },
  "bugs": {
    "url": "https://github.com/PaperBackPear3/microHarnesses/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.test.d.ts"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\""
  },
  "peerDependencies": {
    "@micro-harnesses/core": "^3.0.9"
  }
}
